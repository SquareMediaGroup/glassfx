{
  "name": "glassfx",
  "version": "0.1.0",
  "description": "Real-refraction glassmorphism for any element — backdrop lensing, chromatic dispersion, depth and a cursor-tracking bloom. Pure CSS + ~1KB JS, with graceful fallback. Framework-agnostic, plus optional React bindings.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": "./src/index.js",
    "./react": "./src/react.js",
    "./glass.css": "./src/glass.css",
    "./css": "./src/glass.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./src/index.js",
    "*.css"
  ],
  "workspaces": [
    "site"
  ],
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "demo": "python3 -m http.server 8080",
    "build": "npm run build --workspace site"
  },
  "keywords": [
    "glassmorphism",
    "glass",
    "liquid-glass",
    "backdrop-filter",
    "refraction",
    "chromatic-aberration",
    "frosted",
    "blur",
    "css",
    "react",
    "ui"
  ],
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "license": "MIT",
  "author": "Square Media Group",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SquareMediaGroup/glassfx.git"
  },
  "homepage": "https://github.com/SquareMediaGroup/glassfx#readme",
  "bugs": {
    "url": "https://github.com/SquareMediaGroup/glassfx/issues"
  }
}
